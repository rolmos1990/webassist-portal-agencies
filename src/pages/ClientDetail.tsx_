                  </ul>

                  <div className="tab-content pt-3">
                    <div className="tab-pane fade show active" id="tabPlans" role="tabpanel">
                      {plans.map((p) => (
                        <PlanRow key={p.number} plan={p} />
                      ))}
                    </div>

                    <div className="tab-pane fade" id="tabQuotes" role="tabpanel">
                      {quotes.length === 0 ? (
                        <div className="text-body-secondary p-3">No standing quotes at the moment.</div>
                      ) : (
                        quotes.map((q) => <div key={q.id} className="p-3">{q.title}</div>)
                      )}
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
